rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // AURAID baseline:
    // - App must authenticate (anonymous/user) before Firestore writes.
    // - Training data under trainees/{traineeId}/sessions/{sessionId}.
    // - Emergency data under emergency_sessions/{sessionId} and subcollections.
    match /trainees/{traineeId} {
      allow read, write: if request.auth != null;
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null;
        match /{sub=**} {
          allow read, write: if request.auth != null;
        }
      }
    }

    match /emergency_sessions/{sessionId} {
      allow read, write: if request.auth != null;
      match /{sub=**} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
